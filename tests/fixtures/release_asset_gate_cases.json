  "cases": [
    {
      "name": "complete release",
      "valid": true
    },
    {
      "name": "missing checksums asset",
      "remove_assets": ["checksums.txt"],
      "errors": ["missing release asset: checksums.txt"]
    },
    {
      "name": "missing archive",
