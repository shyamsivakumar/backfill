      "errors": ["missing release asset: backfill_linux_arm64.tar.gz"]
    },
    {
      "name": "checksums omit archive",
      "remove_checksum_entries": ["backfill_darwin_arm64.tar.gz"],
      "errors": ["checksums.txt does not mention: backfill_darwin_arm64.tar.gz"]
    },
    {
      "name": "malformed checksum line",
      "append_checksum_lines": ["not-a-checksum"],
      "errors": ["malformed checksums.txt line"]
    },
    {
      "name": "duplicate checksum entry",
      "duplicate_checksum_entries": ["backfill_linux_amd64.tar.gz"],
      "errors": ["duplicate checksum entry: backfill_linux_amd64.tar.gz"]
    },
    {
      "name": "draft release",
      "release_overrides": {"draft": true},
      "errors": ["release must be explicitly non-draft"]
    },
    {
      "name": "prerelease",
      "release_overrides": {"prerelease": true},
      "errors": ["release must be explicitly non-prerelease"]
    },
    {
      "name": "extra asset",
      "add_assets": ["release-notes.md"],
      "valid": true
    },
    {
      "name": "changed asset ordering",
      "reverse_assets": true,
      "valid": true
    },
    {
      "name": "duplicate asset name",
      "duplicate_assets": ["backfill_linux_amd64.tar.gz"],
      "errors": ["duplicate release asset: backfill_linux_amd64.tar.gz"]
    },
    {
      "name": "leading-v tag",
      "tag": "v9.8.7",
      "release_overrides": {"tag_name": "v9.8.7"},
      "valid": true
    },
    {
      "name": "tag without leading v",
      "tag": "1.2.3",
      "release_overrides": {"tag_name": "1.2.3"},
      "errors": ["tag must use the release form vMAJOR.MINOR.PATCH"]
    }
  ]
}
